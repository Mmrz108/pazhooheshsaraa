# Liara production — copy into Liara Console > Settings > Environment Variables
# App: test-mirzaei | URL: https://test-mirzaei.liara.run
#
# 1) Create a PostgreSQL database in Liara panel
# 2) Copy connection info from the database Connection tab
# 3) Paste below into app Environment Variables
# 4) USE_SQLITE must be False (SQLite is read-only on Liara)

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
USE_SQLITE=False
USE_REDIS=False

# Option A — individual vars (Liara panel names)
POSTGRESQL_DB_HOST=your-host.liara.cloud
POSTGRESQL_DB_PORT=5432
POSTGRESQL_DB_USER=root
POSTGRESQL_DB_PASS=your-password
POSTGRESQL_DB_NAME=postgres

# Option B — single connection string (alternative to Option A)
# DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DBNAME

# Optional: custom domain
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# OTP / SMS
SMS_PROVIDER=kavenegar
SMS_API_KEY=
SMS_SENDER=2000660110
KAVENEGAR_OTP_TEMPLATE=otp
SMS_FALLBACK_CONSOLE=False
OTP_DEBUG_VISIBLE=False

# Admin gate
ADMIN_SITE_PASSWORD=choose-a-strong-password

# Payment (update domain after deploy)
PAYMENT_CALLBACK_URL=https://test-mirzaei.liara.run/api/payments/verify/
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

# Liara production — copy into Liara Console > Settings > Environment Variables
# App: test-mirzaei | URL: https://test-mirzaei.liara.run
#
# SQLite on Liara requires a persistent disk:
# 1) Liara Console -> Disks -> create disk named: data
# 2) liara.json already mounts it to data/
# 3) Set env vars below and deploy

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
USE_SQLITE=True
USE_REDIS=False

# Writable Liara disk (create disk named "data" in console; mounted to data/)
# SQLITE_DB_PATH=data/db.sqlite3
# MEDIA_ROOT=data
# LIARA_DATA_DIR=data

# Optional: PostgreSQL instead of SQLite
# USE_SQLITE=False
# POSTGRESQL_DB_HOST=your-host.liara.cloud
# POSTGRESQL_DB_PORT=5432
# POSTGRESQL_DB_USER=root
# POSTGRESQL_DB_PASS=your-password
# POSTGRESQL_DB_NAME=postgres

# OTP / SMS
SMS_PROVIDER=kavenegar
SMS_API_KEY=
SMS_SENDER=2000660110
KAVENEGAR_OTP_TEMPLATE=otp
SMS_FALLBACK_CONSOLE=False
OTP_DEBUG_VISIBLE=False

# Admin gate
ADMIN_SITE_PASSWORD=choose-a-strong-password

# Payment — Sadad Melli (melli_new)
PAYMENT_GATEWAY=melli_new
PAYMENT_GATEWAY_ENABLED=True
PAYMENT_DIRECT_REDIRECT=True
SADAD_MERCHANT_ID=
SADAD_TERMINAL_ID=
SADAD_TERMINAL_KEY=
PAYMENT_CALLBACK_URL=https://test-mirzaei.liara.run/api/payments/verify/
PAYMENT_SUCCESS_REDIRECT_URL=/courses/
PAYMENT_FAILED_REDIRECT_URL=/courses/?payment=failed

# Zarinpal (legacy)
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

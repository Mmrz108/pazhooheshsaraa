# Django
DEBUG=True
SECRET_KEY=change-me-to-a-secure-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=pazhooheshsaraa.settings

# Use SQLite for local development without Docker (False in production)
USE_SQLITE=False

# Set False for local dev without Redis/Docker
USE_REDIS=True

DB_NAME=pazhooheshsaraa
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# OTP
OTP_EXPIRY_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5
OTP_DEBUG_VISIBLE=False

# SMS (kavenegar | console)
SMS_PROVIDER=kavenegar
SMS_API_KEY=your-kavenegar-api-key
SMS_SENDER=2000660110
KAVENEGAR_OTP_TEMPLATE=otp
SMS_FALLBACK_CONSOLE=False

# Bale OTP â€” https://docs.bale.ai/safir
BALE_ENABLED=False
BALE_BOT_ID=0
BALE_BOT_TOKEN=
BALE_BOT_USERNAME=
BALE_API_ACCESS_KEY=your-safir-api-access-key
BALE_CLIENT_ID=your-gateway-client-id
BALE_CLIENT_SECRET=your-gateway-client-secret
BALE_API_URL=https://safir.bale.ai/api/v3/send_message

# Zarinpal Payment Gateway
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=True
PAYMENT_CALLBACK_URL=http://localhost:8000/api/payments/verify/

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/

